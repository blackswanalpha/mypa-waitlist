# ─────────────────────────────────────────────────────────────────────────────
# mypa-waitlist environment variables
# Copy to .env.local for local dev. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Next.js (public) — written automatically by `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment

# ─────────────────────────────────────────────────────────────────────────────
# The following live on the CONVEX deployment, NOT in this file.
# Set them with:  npx convex env set <NAME> "<value>"
#
#   ADMIN_EMAILS        comma-separated allowlist of admin emails
#                       e.g.  npx convex env set ADMIN_EMAILS "you@example.com"
#   RESEND_API_KEY      Resend API key (re_...)
#   SITE_URL            the app origin (http://localhost:3000 in dev; Vercel URL in prod)
#   JWT_PRIVATE_KEY     generated by `npx @convex-dev/auth`
#   JWKS                generated by `npx @convex-dev/auth`
# ─────────────────────────────────────────────────────────────────────────────
